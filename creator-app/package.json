{
  "name": "whitelist-bypass-creator",
  "version": "0.3.7",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/bot/security.test.js .test-dist/bot/bot-manager.test.js .test-dist/bot/command-mode.test.js .test-dist/control/poc/poc-protocol.test.js .test-dist/control/poc/poc-handler.test.js .test-dist/control/poc/poc-bot-manager-integration.test.js .test-dist/control/poc/poc-mode-static.test.js .test-dist/main/process-termination.test.js .test-dist/main/headless-process-events.test.js .test-dist/main/trust-policy.test.js .test-dist/main/trust-boundary-static.test.js .test-dist/main/protected-settings.test.js .test-dist/main/protected-settings-smoke-policy.test.js .test-dist/main/cookie-domain-policy.test.js .test-dist/main/ephemeral-cookie-file.test.js .test-dist/main/legacy-settings-validation.test.js .test-dist/main/wb-device-id.test.js .test-dist/main/protected-settings-static.test.js .test-dist/renderer/protected-settings-migration.test.js .test-dist/renderer/protected-settings-manager.test.js .test-dist/renderer/protected-settings-form.test.js .test-dist/renderer/headless-event-state.test.js",
    "smoke:electron": "node tools/smoke-electron.js",
    "start": "tsc && electron .",
    "start:dev": "electron .",
    "smoke:protected-storage": "node tools/smoke-protected-storage.js"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "whitelist.bypass.creator",
    "productName": "WhitelistBypass Creator",
    "directories": {
      "output": "../prebuilts"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "styles/**/*",
      "scripts/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../hooks/dc-creator-vk.js",
        "to": "hooks/dc-creator-vk.js"
      },
      {
        "from": "../hooks/video-vk.js",
        "to": "hooks/video-vk.js"
      },
      {
        "from": "../hooks/video-telemost.js",
        "to": "hooks/video-telemost.js"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "extraResources": [
        {
          "from": "../relay/relay-darwin",
          "to": "relay"
        },
        {
          "from": "../headless/headless-vk-darwin",
          "to": "headless-vk-creator"
        },
        {
          "from": "../headless/headless-telemost-darwin",
          "to": "headless-telemost-creator"
        },
        {
          "from": "../headless/headless-wbstream-darwin",
          "to": "headless-wbstream-creator"
        },
        {
          "from": "../headless/headless-dion-darwin",
          "to": "headless-dion-creator"
        }
      ]
    },
    "win": {
      "target": "portable",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "resources/icon.ico",
      "extraResources": [
        {
          "from": "../relay/relay-bundle.exe",
          "to": "relay.exe"
        },
        {
          "from": "../headless/headless-vk-bundle.exe",
          "to": "headless-vk-creator.exe"
        },
        {
          "from": "../headless/headless-telemost-bundle.exe",
          "to": "headless-telemost-creator.exe"
        },
        {
          "from": "../headless/headless-wbstream-bundle.exe",
          "to": "headless-wbstream-creator.exe"
        },
        {
          "from": "../headless/headless-dion-bundle.exe",
          "to": "headless-dion-creator.exe"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "resources/icon.png",
      "extraResources": [
        {
          "from": "../relay/relay-bundle",
          "to": "relay"
        },
        {
          "from": "../headless/headless-vk-bundle",
          "to": "headless-vk-creator"
        },
        {
          "from": "../headless/headless-telemost-bundle",
          "to": "headless-telemost-creator"
        },
        {
          "from": "../headless/headless-wbstream-bundle",
          "to": "headless-wbstream-creator"
        },
        {
          "from": "../headless/headless-dion-bundle",
          "to": "headless-dion-creator"
        }
      ]
    }
  }
}
