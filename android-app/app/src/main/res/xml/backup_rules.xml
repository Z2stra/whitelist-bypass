<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- VK ID 2.7.1 keeps access/refresh state in encrypted preferences. The
         encrypted file and SDK device identity must never cross devices or be
         restored without the originating Android Keystore key. -->
    <exclude domain="sharedpref" path="vkid_encrypted_shared_prefs.xml" />
    <exclude domain="sharedpref" path="app_prefs.xml" />
</full-backup-content>
