<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The official VK ID dependency remains compile-time code for the shared
         sources, but normal release APKs must expose no VK auth entry points. -->
    <application>
        <activity
            android:name="com.vk.id.internal.auth.AuthActivity"
            tools:node="remove" />
        <activity
            android:name="com.vk.id.internal.auth.RedirectUriReceiverActivity"
            tools:node="remove" />
    </application>
</manifest>
