# Copy this file to android-app/keystore.properties (which is ignored) only when
# environment variables are not practical. Never commit real values.
#
# Preferred environment variables (all four signing values must be supplied
# together; a partial environment is rejected rather than mixed with this file):
#   WLB_POC_KEYSTORE_PATH
#   WLB_POC_KEYSTORE_PASSWORD
#   WLB_POC_KEY_ALIAS
#   WLB_POC_KEY_PASSWORD
#   WLB_POC_BUILD_NUMBER (strictly increasing 1..999 for signed live POC APKs)

wlb.poc.storeFile=D:\\wlb-secrets\\wlb-poc.keystore
wlb.poc.storePassword=replace-locally
wlb.poc.keyAlias=wlb-poc
wlb.poc.keyPassword=replace-locally
