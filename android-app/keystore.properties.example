# Optional fallback for direct Gradle POC builds only.
#
# Copy this file to android-app/keystore.properties (which is ignored) when
# environment variables are not practical for direct Gradle invocation.
# Never commit real values.
#
# The keystore path must resolve OUTSIDE the repository. Paths under ignored
# repository directories such as secrets/, local-secrets/ or local-artifacts/
# are rejected by the Gradle POC gate.
#
# The canonical accepted signing/update smoke uses:
#   tools/invoke-poc-signing-smoke.ps1
#
# That interactive wrapper prompts for passwords without putting them in shell
# history, and calls the environment-only low-level helper. Direct Gradle output
# from this properties fallback is useful for development/CI verification but is
# not accepted as a source-free live artifact by itself.
#
# WLB_POC_BUILD_NUMBER is public per-build identity, not a secret. Gradle
# validates only the integer range 1..999; never reuse or decrease an accepted
# live number.

wlb.poc.storeFile=D:\\northbridge-secrets\\northbridge-mobile.p12
wlb.poc.storePassword=replace-locally
wlb.poc.keyAlias=northbridge-mobile
wlb.poc.keyPassword=replace-locally
