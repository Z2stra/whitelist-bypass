# Optional fallback for direct Gradle POC builds only.
#
# Copy this file to android-app/keystore.properties (which is ignored) when
# environment variables are not practical for direct Gradle invocation.
# Never commit real values.
#
# The canonical reproducible helper tools/preserve-poc-signing-smoke.ps1
# deliberately does NOT parse this file. Run that helper only with the complete
# environment set below so PowerShell never implements a second, subtly
# different parser for Java .properties escaping rules:
#   WLB_POC_KEYSTORE_PATH
#   WLB_POC_KEYSTORE_PASSWORD
#   WLB_POC_KEY_ALIAS
#   WLB_POC_KEY_PASSWORD
#
# WLB_POC_BUILD_NUMBER is public per-build identity, not a secret. Gradle
# validates only the integer range 1..999; never reuse or decrease an accepted
# live number.

wlb.poc.storeFile=D:\\wlb-secrets\\wlb-poc.keystore
wlb.poc.storePassword=replace-locally
wlb.poc.keyAlias=wlb-poc
wlb.poc.keyPassword=replace-locally
